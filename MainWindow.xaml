<Window x:Class="UltraLightTCPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="UltraLight TC Player"
        Width="1120"
        Height="720"
        MinWidth="860"
        MinHeight="560"
        Background="#101214"
        Foreground="#F4F6F8"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        PreviewKeyDown="Window_KeyDown"
        Focusable="True">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="#2B3035"
                BorderThickness="1"
                Background="#050607">
            <Grid>
                <MediaElement x:Name="Player"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Manual"
                              ScrubbingEnabled="True"
                              Stretch="Uniform"
                              MediaOpened="Player_MediaOpened"
                              MediaEnded="Player_MediaEnded"
                              MediaFailed="Player_MediaFailed" />
                <TextBlock x:Name="DropHintText"
                           Text="動画ファイルを開くか、ここへドロップ"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#8D969E"
                           FontSize="18" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Open" Click="OpenButton_Click" />
                <Button x:Name="PlayPauseButton"
                        Width="64"
                        Content="Play"
                        Click="PlayPauseButton_Click" />
            </StackPanel>

            <Slider x:Name="SeekSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="1"
                    Margin="8,0,14,0"
                    VerticalAlignment="Center"
                    PreviewMouseLeftButtonDown="SeekSlider_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp" />

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="MuteButton"
                        Width="64"
                        Content="Mute"
                        Click="MuteButton_Click" />
                <Slider x:Name="VolumeSlider"
                        Width="110"
                        Minimum="0"
                        Maximum="1"
                        Value="0.8"
                        VerticalAlignment="Center"
                        ValueChanged="VolumeSlider_ValueChanged" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="TC"
                           Margin="0,0,8,0"
                           Foreground="#AAB3BC" />
                <TextBlock x:Name="CurrentTimecodeText"
                           Grid.Column="1"
                           Width="138"
                           Text="00:00:00:00"
                           FontFamily="Cascadia Mono, Consolas"
                           FontSize="20" />
                <TextBlock Grid.Column="2"
                           Text="/"
                           Margin="6,0"
                           Foreground="#AAB3BC"
                           FontFamily="Cascadia Mono, Consolas"
                           FontSize="20" />
                <TextBlock x:Name="DurationTimecodeText"
                           Grid.Column="3"
                           Width="138"
                           Text="--:--:--:--"
                           FontFamily="Cascadia Mono, Consolas"
                           FontSize="20" />
                <TextBlock x:Name="FpsText"
                           Grid.Column="4"
                           Text="FPS --"
                           Margin="18,0,0,0"
                           Foreground="#AAB3BC"
                           HorizontalAlignment="Left" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="IN" Margin="0,0,8,0" Foreground="#AAB3BC" />
                    <TextBlock x:Name="InTimecodeText"
                               Width="120"
                               Text="--:--:--:--"
                               FontFamily="Cascadia Mono, Consolas"
                               FontSize="18" />
                    <TextBlock Text="OUT" Margin="18,0,8,0" Foreground="#AAB3BC" />
                    <TextBlock x:Name="OutTimecodeText"
                               Width="120"
                               Text="--:--:--:--"
                               FontFamily="Cascadia Mono, Consolas"
                               FontSize="18" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Clear In" Click="ClearInButton_Click" />
                    <Button Content="Clear Out" Click="ClearOutButton_Click" />
                    <Button Content="Clear All" Click="ClearAllButton_Click" Margin="0" />
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="FfmpegCommandText"
                     Grid.Column="0"
                     Height="34"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center"
                     Background="#171A1D"
                     Foreground="#F4F6F8"
                     BorderBrush="#2B3035"
                     FontFamily="Cascadia Mono, Consolas"
                     Text="IN / OUTを設定するとffmpegコマンドを生成します" />
            <Button x:Name="CopyCommandButton"
                    Grid.Column="1"
                    Content="Copy"
                    IsEnabled="False"
                    Margin="10,0,0,0"
                    Click="CopyCommandButton_Click" />
        </Grid>
    </Grid>
</Window>
